{
  "name": "lekkertaal",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "deploy": "pnpm run build && wrangler deploy",
    "prepare": "husky",
    "seed:ingest": "tsx scripts/seed-ingest.ts",
    "seed:load": "tsx scripts/seed-load.ts",
    "seed:users": "tsx scripts/seed-users.ts",
    "seed:image-drills": "tsx scripts/seed-image-drills.ts",
    "db:generate": "drizzle-kit generate",
    "db:push:local": "wrangler d1 migrations apply lekkertaal_db --local",
    "db:push:remote": "wrangler d1 migrations apply lekkertaal_db --remote",
    "typecheck": "tsc --noEmit",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "dev:bypass-auth": "bash scripts/dev-bypass-auth.sh",
    "quality": "pnpm test && pnpm build",
    "quality:full": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/google": "^3.0.73",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/react": "^3.0.184",
    "@clerk/backend": "^3.4.7",
    "@clerk/tanstack-react-start": "^1.2.3",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@logtape/logtape": "^2.0.7",
    "@logtape/sentry": "^2.0.7",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "ai": "^6.0.180",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.545.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@clerk/testing": "^2.0.27",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@google/generative-ai": "^0.24.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.6",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.20.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^17.0.4",
    "openai": "^6.37.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}
