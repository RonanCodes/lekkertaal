#!/usr/bin/env sh
# Quality gate. Mirrors GitHub Actions `Build (PR + main)` job + adds local test run.
# Bypass with SKIP_QUALITY_CHECKS=1 only in real emergencies.

if [ "$SKIP_QUALITY_CHECKS" = "1" ]; then
  echo "⚠️  SKIP_QUALITY_CHECKS=1 set; bypassing pre-push gate"
  exit 0
fi

set -e
# Build first so routeTree.gen.ts exists (gitignored, generated as a side
# effect of the tanstackStart vite plugin). Typecheck + lint need it to
# resolve route-id types. Local dev gets it via `vite dev`; this hook + CI
# need an explicit build first.
echo "▶ build"
pnpm build
echo "▶ typecheck"
pnpm typecheck
echo "▶ lint"
pnpm lint
echo "▶ test"
pnpm test
echo "✓ pre-push quality gate passed"
