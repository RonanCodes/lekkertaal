#!/usr/bin/env sh
# Quality gate. Mirrors GitHub Actions `Build (PR + main)` job + adds local test run.
# Bypass with SKIP_QUALITY_CHECKS=1 only in real emergencies.

if [ "$SKIP_QUALITY_CHECKS" = "1" ]; then
  echo "⚠️  SKIP_QUALITY_CHECKS=1 set; bypassing pre-push gate"
  exit 0
fi

set -e
echo "▶ typecheck"
pnpm typecheck
echo "▶ lint"
pnpm lint
echo "▶ test"
pnpm test
echo "▶ build"
pnpm build
echo "✓ pre-push quality gate passed"
